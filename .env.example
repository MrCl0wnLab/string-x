# String-X Environment Configuration Example
#
# Copy this file to .env and fill in your actual values
# DO NOT commit .env with actual secrets to version control!

# ==========================================
# THIRD-PARTY API KEYS & TOKENS
# ==========================================
STRX_SHODAN_API_KEY=your_shodan_api_key_here
STRX_VIRUSTOTAL_API_KEY=your_virustotal_api_key_here
STRX_IPINFO_TOKEN=your_ipinfo_token_here
STRX_GOOGLE_API_KEY=your_google_api_key_here
STRX_OPENAI_API_KEY=your_openai_api_key_here
STRX_GEMINI_API_KEY=your_gemini_api_key_here

# ==========================================
# MESSAGING & NOTIFICATIONS
# ==========================================
STRX_TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
STRX_TELEGRAM_CHAT_ID=your_telegram_chat_id_here
STRX_SLACK_TOKEN=your_slack_token_here
STRX_SLACK_CHANNEL=your_slack_channel_here

# ==========================================
# DATABASE CREDENTIALS
# ==========================================
STRX_MYSQL_PASSWORD=your_secure_mysql_password_here
STRX_OPENSEARCH_PASSWORD=your_secure_opensearch_password_here

# ==========================================
# CONNECTION CREDENTIALS
# ==========================================
STRX_FTP_PASSWORD=your_ftp_password_here
STRX_SSH_PASSWORD=your_ssh_password_here

# ==========================================
# CUSTOM OVERRIDES (Optional)
# ==========================================
# STRX_NOTIFICATION_ICON_PATH=/custom/path/to/your/icon.png
# STRX_LOG_DIRECTORY=/custom/log/path
# STRX_SQLITE_DATABASE=/custom/path/to/database.db