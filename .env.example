# String-X Environment Configuration for Production/Custom Settings
#
# This file shows how to override the default values from .env
# Copy relevant sections to your production .env file and fill in actual values
# DO NOT commit this file with actual secrets to version control!

# ==========================================
# SENSITIVE CREDENTIALS (Override defaults in .env)
# ==========================================

# Third-party API Keys
STRX_SHODAN_API_KEY=your_shodan_api_key_here
STRX_VIRUSTOTAL_API_KEY=your_virustotal_api_key_here
STRX_IPINFO_TOKEN=your_ipinfo_token_here
STRX_GOOGLE_API_KEY=your_google_api_key_here
STRX_OPENAI_API_KEY=your_openai_api_key_here
STRX_GEMINI_API_KEY=your_gemini_api_key_here

# Messaging/Notification Services
STRX_TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
STRX_TELEGRAM_CHAT_ID=your_telegram_chat_id_here
STRX_SLACK_TOKEN=your_slack_token_here
STRX_SLACK_CHANNEL=your_slack_channel_here

# Database Passwords
STRX_MYSQL_PASSWORD=your_secure_mysql_password_here
STRX_OPENSEARCH_PASSWORD=your_secure_opensearch_password_here

# Connection Credentials
STRX_FTP_PASSWORD=your_ftp_password_here
STRX_SSH_USERNAME=your_ssh_username_here
STRX_SSH_PASSWORD=your_ssh_password_here

# ==========================================
# ENVIRONMENT-SPECIFIC OVERRIDES (Optional)
# ==========================================

# Custom paths for different deployments
# STRX_NOTIFICATION_ICON_PATH=/opt/string-x/custom-icon.png
# STRX_NOTIFICATION_AUDIO_PATH=/opt/string-x/custom-notification.wav
# STRX_LOG_DIRECTORY=/var/log/string-x
# STRX_SQLITE_DATABASE=/opt/string-x/data/strx.db

# Performance tuning for production
# STRX_THREAD_MAX=20
# STRX_CONNECTION_POOL_SIZE=25
# STRX_MEMORY_LIMIT=1024

# Different output formats for specific use cases
# STRX_DEFAULT_OUTPUT_FORMAT=json
# STRX_OUTPUT_FORMATS=json,xml,csv