# String-X Default Configuration
#
# This file contains all default configuration values for String-X.
# Sensitive values (API keys, passwords) are commented out - uncomment and set them as needed.
# You can override any value by setting the corresponding environment variable.

# ==========================================
# APPLICATION INFORMATION  
# ==========================================
STRX_VERSION=1.0.0
STRX_AUTHOR=Cleiton Pinheiro aka MrCl0wn
STRX_URL=https://github.com/MrCl0wnLab/string-x
STRX_EMAIL=mrcl0wnlab@gmail.com
STRX_TWITTER=https://twitter.com/MrCl0wnLab
STRX_LICENSE=MIT

# ==========================================
# LOGGING CONFIGURATION
# ==========================================
STRX_LOG_LEVEL=INFO
STRX_LOG_DIRECTORY=output
STRX_LOG_TIME_FORMAT=%d-%m-%Y-%H
STRX_LOG_FILE_LAST=output-last-value.log
STRX_ENABLE_FILE_LOGGING=true
STRX_LOG_MAX_FILE_SIZE=100
STRX_LOG_BACKUP_COUNT=5

# ==========================================
# THREADING CONFIGURATION
# ==========================================
STRX_THREAD_MAX=10
STRX_THREAD_TIMEOUT=300
STRX_THREAD_POOL_MAX_WORKERS=20

# ==========================================
# HTTP REQUEST CONFIGURATION
# ==========================================
STRX_USER_AGENT=String-X/1.0.0
STRX_REQUEST_TIMEOUT=30
STRX_RETRY_OPERATIONS=3
STRX_RETRY_DELAY=2
STRX_RETRY_MAX_DELAY=60
STRX_CONNECTION_POOL_SIZE=10

# ==========================================
# SECURITY CONFIGURATION
# ==========================================
STRX_MAX_INPUT_SIZE=1048576
STRX_MAX_THREAD_COUNT=100
STRX_MAX_TIMEOUT=3600
STRX_MAX_STRING_LIST_SIZE=10000
STRX_MAX_COMMAND_LENGTH=8192
STRX_SECURITY_VALIDATION=true

# ==========================================
# OUTPUT CONFIGURATION
# ==========================================
STRX_DEFAULT_OUTPUT_FORMAT=txt
STRX_OUTPUT_FORMATS=txt,csv,json,xml
STRX_OUTPUT_MAX_FILE_SIZE=500
STRX_OUTPUT_DIR_PERMISSIONS=755

# ==========================================
# BANNER CONFIGURATION
# ==========================================
STRX_BANNER_DEFAULT=strx
STRX_BANNER_RANDOM=true
STRX_BANNER_ENABLED=true

# ==========================================
# NOTIFICATION CONFIGURATION
# ==========================================
STRX_NOTIFICATIONS_ENABLED=false
# STRX_NOTIFICATION_ICON_PATH=/custom/path/to/your/icon.png
STRX_NOTIFICATION_APP_NAME=String-X

# ==========================================
# PERFORMANCE TUNING
# ==========================================
STRX_ENABLE_CACHING=true
STRX_CACHE_TTL=3600
STRX_CACHE_SIZE=1000
STRX_MEMORY_LIMIT=512
STRX_MIN_DISK_SPACE=100

# ==========================================
# DEVELOPMENT/DEBUG OPTIONS
# ==========================================
STRX_DEBUG=false
STRX_VERBOSE=false
STRX_DEFAULT_VERBOSE_LEVEL=1
STRX_ENABLE_PROFILING=false
STRX_ENABLE_METRICS=false

# ==========================================
# THIRD-PARTY API KEYS & TOKENS (Sensitive - Uncomment to use)
# ==========================================
# STRX_SHODAN_API_KEY=your_shodan_api_key_here
# STRX_VIRUSTOTAL_API_KEY=your_virustotal_api_key_here
# STRX_IPINFO_TOKEN=your_ipinfo_token_here
# STRX_GOOGLE_API_KEY=your_google_api_key_here
# STRX_OPENAI_API_KEY=your_openai_api_key_here
# STRX_GEMINI_API_KEY=your_gemini_api_key_here

# ==========================================
# MESSAGING CREDENTIALS (Sensitive - Uncomment to use)
# ==========================================
# STRX_TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# STRX_TELEGRAM_CHAT_ID=your_telegram_chat_id_here
# STRX_SLACK_TOKEN=your_slack_token_here
# STRX_SLACK_CHANNEL=your_slack_channel_here

# ==========================================
# DATABASE CONNECTION DEFAULTS
# ==========================================
# MySQL
STRX_MYSQL_HOST=localhost
STRX_MYSQL_PORT=3306
STRX_MYSQL_DATABASE=strx_db
STRX_MYSQL_USER=strx_user
# STRX_MYSQL_PASSWORD=your_secure_mysql_password_here
STRX_MYSQL_CHARSET=utf8mb4
STRX_MYSQL_TIMEOUT=30

# SQLite
STRX_SQLITE_DATABASE=output/strx.db
STRX_SQLITE_TIMEOUT=30

# OpenSearch
STRX_OPENSEARCH_HOST=localhost
STRX_OPENSEARCH_PORT=9200
STRX_OPENSEARCH_USERNAME=admin
# STRX_OPENSEARCH_PASSWORD=your_secure_opensearch_password_here
STRX_OPENSEARCH_USE_SSL=true
STRX_OPENSEARCH_VERIFY_CERTS=false
STRX_OPENSEARCH_TIMEOUT=60
STRX_OPENSEARCH_INDEX=strx-data
STRX_OPENSEARCH_RETRY=3
STRX_OPENSEARCH_RETRY_DELAY=5

# ==========================================
# CONNECTION DEFAULTS
# ==========================================
# FTP
STRX_FTP_HOST=localhost
STRX_FTP_PORT=21
STRX_FTP_USERNAME=anonymous
# STRX_FTP_PASSWORD=your_ftp_password_here
STRX_FTP_TIMEOUT=30

# SSH
STRX_SSH_HOST=localhost
STRX_SSH_PORT=22
# STRX_SSH_USERNAME=your_ssh_username_here
# STRX_SSH_PASSWORD=your_ssh_password_here
STRX_SSH_TIMEOUT=30

# ==========================================
# AI MODULES DEFAULTS
# ==========================================
STRX_OPENAI_MODEL=gpt-3.5-turbo
STRX_OPENAI_TIMEOUT=30
STRX_OPENAI_MAX_TOKENS=1000

STRX_GEMINI_MODEL=gemini-pro
STRX_GEMINI_TIMEOUT=30

# ==========================================
# GOOGLE SEARCH CONFIGURATION
# ==========================================
STRX_GOOGLE_CSE_ID_FILE=src/stringx/config/google_cse_id.txt
STRX_GOOGLE_SEARCH_TIMEOUT=10
STRX_GOOGLE_MAX_RESULTS=100