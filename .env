# String-X Environment Configuration
#
# This file contains the default environment variables used by String-X.
# All variables follow the STRX_ prefix convention as defined in setting.py
#
# You can customize these values or set them as system environment variables.
# System environment variables take precedence over values in this file.

# ==========================================
# APPLICATION INFORMATION
# ==========================================
# STRX_VERSION=1.0.0
# STRX_AUTHOR=Cleiton Pinheiro aka MrCl0wn
# STRX_URL=https://github.com/MrCl0wnLab/string-x
# STRX_EMAIL=mrcl0wnlab@gmail.com
# STRX_TWITTER=https://twitter.com/MrCl0wnLab
# STRX_LICENSE=MIT

# ==========================================
# LOGGING CONFIGURATION
# ==========================================
# STRX_LOG_LEVEL=INFO
# STRX_LOG_DIRECTORY=output
# STRX_LOG_TIME_FORMAT=%d-%m-%Y-%H
# STRX_LOG_FILE_LAST=output-last-value.log
# STRX_ENABLE_FILE_LOGGING=true
# STRX_LOG_MAX_FILE_SIZE=100
# STRX_LOG_BACKUP_COUNT=5

# ==========================================
# THREADING CONFIGURATION  
# ==========================================
# STRX_THREAD_MAX=10
# STRX_THREAD_TIMEOUT=300
# STRX_THREAD_POOL_MAX_WORKERS=20

# ==========================================
# HTTP REQUEST CONFIGURATION
# ==========================================
# STRX_USER_AGENT=String-X/1.0.0
# STRX_REQUEST_TIMEOUT=30
# STRX_RETRY_OPERATIONS=3
# STRX_RETRY_DELAY=2
# STRX_RETRY_MAX_DELAY=60
# STRX_CONNECTION_POOL_SIZE=10

# ==========================================
# SECURITY CONFIGURATION
# ==========================================
# STRX_MAX_INPUT_SIZE=1048576
# STRX_MAX_THREAD_COUNT=100
# STRX_MAX_TIMEOUT=3600
# STRX_MAX_STRING_LIST_SIZE=10000
# STRX_MAX_COMMAND_LENGTH=8192
# STRX_SECURITY_VALIDATION=true

# ==========================================
# OUTPUT CONFIGURATION
# ==========================================
# STRX_DEFAULT_OUTPUT_FORMAT=txt
# STRX_OUTPUT_FORMATS=txt,csv,json,xml
# STRX_OUTPUT_MAX_FILE_SIZE=500
# STRX_OUTPUT_DIR_PERMISSIONS=755

# ==========================================
# BANNER CONFIGURATION
# ==========================================
# STRX_BANNER_DEFAULT=strx
# STRX_BANNER_RANDOM=true
# STRX_BANNER_ENABLED=true

# ==========================================
# NOTIFICATION CONFIGURATION
# ==========================================
# Enable desktop notifications by default (users can override with -notify)
# STRX_NOTIFICATIONS_ENABLED=false

# Direct path to notification icon (takes precedence over PROJECT_ROOT + asset/icon.png)
# STRX_NOTIFICATION_ICON_PATH=/custom/path/to/icon.png

# Notification app name (displayed in system notifications)
# STRX_NOTIFICATION_APP_NAME=String-X

# Examples of custom icon paths:
# STRX_NOTIFICATION_ICON_PATH=/mnt/dadosm2/Documentos/string-x/asset/logo.png
# STRX_NOTIFICATION_ICON_PATH=/usr/share/icons/custom-strx-icon.png
# STRX_NOTIFICATION_ICON_PATH=/home/user/.config/stringx/custom-icon.png

# ==========================================
# DEVELOPMENT/DEBUG OPTIONS
# ==========================================
# STRX_DEBUG=false
# STRX_VERBOSE=false
# STRX_DEFAULT_VERBOSE_LEVEL=1
# STRX_ENABLE_PROFILING=false
# STRX_ENABLE_METRICS=false

# ==========================================
# PERFORMANCE TUNING
# ==========================================
# STRX_ENABLE_CACHING=true
# STRX_CACHE_TTL=3600
# STRX_CACHE_SIZE=1000
# STRX_MEMORY_LIMIT=512
# STRX_MIN_DISK_SPACE=100

# ==========================================
# THIRD-PARTY SERVICES (API KEYS)
# ==========================================
# STRX_SHODAN_API_KEY=
# STRX_VIRUSTOTAL_API_KEY=
# STRX_IPINFO_TOKEN=
# STRX_GOOGLE_API_KEY=
# STRX_OPENAI_API_KEY=
# STRX_GEMINI_API_KEY=
# STRX_TELEGRAM_BOT_TOKEN=
# STRX_TELEGRAM_CHAT_ID=
# STRX_SLACK_TOKEN=
# STRX_SLACK_CHANNEL=

# ==========================================
# DATABASE CONNECTIONS
# ==========================================
# MySQL
# STRX_MYSQL_HOST=localhost
# STRX_MYSQL_PORT=3306
# STRX_MYSQL_DATABASE=strx_db
# STRX_MYSQL_USER=strx_user
# STRX_MYSQL_PASSWORD=Str1ngX_p4ss!
# STRX_MYSQL_CHARSET=utf8mb4
# STRX_MYSQL_TIMEOUT=30

# SQLite
# STRX_SQLITE_DATABASE=output/strx.db
# STRX_SQLITE_TIMEOUT=30

# OpenSearch
# STRX_OPENSEARCH_HOST=localhost
# STRX_OPENSEARCH_PORT=9200
# STRX_OPENSEARCH_USERNAME=admin
# STRX_OPENSEARCH_PASSWORD=Str1ngX_p4ss!
# STRX_OPENSEARCH_USE_SSL=true
# STRX_OPENSEARCH_VERIFY_CERTS=false
# STRX_OPENSEARCH_TIMEOUT=60
# STRX_OPENSEARCH_INDEX=strx-data
# STRX_OPENSEARCH_RETRY=3
# STRX_OPENSEARCH_RETRY_DELAY=5

# FTP
# STRX_FTP_HOST=localhost
# STRX_FTP_PORT=21
# STRX_FTP_USERNAME=anonymous
# STRX_FTP_PASSWORD=
# STRX_FTP_TIMEOUT=30

# SSH  
# STRX_SSH_HOST=localhost
# STRX_SSH_PORT=22
# STRX_SSH_USERNAME=
# STRX_SSH_PASSWORD=
# STRX_SSH_TIMEOUT=30